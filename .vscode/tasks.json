{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install desktop dependencies",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build desktop app",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run desktop app",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Package desktop app",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "run",
        "dist"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}